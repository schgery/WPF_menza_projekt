<Window x:Class="WPF_menza_projekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_menza_projekt"
        mc:Ignorable="d"
        Title="🍽 Menza Rendszer" Height="600" Width="1000"
        Background="#1E1A17">

    <Window.Resources>

        <!-- Színpaletta -->
        <SolidColorBrush x:Key="BgDark"       Color="#1E1A17"/>
        <SolidColorBrush x:Key="BgCard"        Color="#2B2520"/>
        <SolidColorBrush x:Key="BgInput"       Color="#3A302A"/>
        <SolidColorBrush x:Key="AccentOrange"  Color="#E8874A"/>
        <SolidColorBrush x:Key="AccentGold"    Color="#D4A843"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#F5ECD7"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#9A8778"/>
        <SolidColorBrush x:Key="BorderSubtle"  Color="#4A3D35"/>

        <!-- Kártya stílus -->
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius"     Value="10"/>
            <Setter Property="Padding"          Value="14"/>
            <Setter Property="Margin"           Value="5"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness"  Value="1"/>
        </Style>

        <!-- Szekció fejléc -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource AccentGold}"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontFamily"   Value="Georgia"/>
            <Setter Property="Margin"       Value="0,0,0,8"/>
        </Style>

        <!-- Label stílus -->
        <Style TargetType="Label">
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Padding"     Value="0,4,6,4"/>
        </Style>

        <!-- TextBox stílus -->
        <Style TargetType="TextBox">
            <Setter Property="Background"        Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"        Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"       Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="6,5"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="CaretBrush"        Value="{StaticResource AccentOrange}"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentOrange}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox stílus -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>

            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Padding" Value="6,4"/>

                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#E8874A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DatePicker stílus -->
        <Style TargetType="DatePicker">
            <Setter Property="Background"       Value="{StaticResource BgInput}"/>
            <!--<Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>-->
            <Setter Property="BorderBrush"      Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="4"/>
            <Setter Property="Margin"           Value="0,4,0,8"/>
        </Style>

        <!-- Gomb stílus -->
        <Style TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource AccentOrange}"/>
            <Setter Property="Foreground"       Value="#1E1A17"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Padding"          Value="10,7"/>
            <Setter Property="Margin"           Value="0,6,0,2"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentGold}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox stílus -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="12"/>
        </Style>

        <!-- ListView stílus -->
        <Style TargetType="ListView">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- ListViewItem stílus -->
        <Style TargetType="ListViewItem">
            <Setter Property="Padding"          Value="8,6"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A302A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4A3520"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentGold}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Elválasztó vonal -->
        <Style x:Key="Divider" TargetType="Separator">
            <Setter Property="Background"  Value="{StaticResource BorderSubtle}"/>
            <Setter Property="Margin"      Value="0,8,0,8"/>
            <Setter Property="Height"      Value="1"/>
        </Style>

    </Window.Resources>

    <!-- Fő grid -->
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── 1. oszlop: Vendégek ── -->
        <Border Style="{StaticResource CardPanel}" Grid.Column="0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionHeader}">👤 VENDÉGEK</TextBlock>
                <ListView SelectionChanged="vendegeklv_SelectionChanged"
                          ItemsSource="{Binding vendegek}"
                          x:Name="vendegeklv"
                          BorderThickness="0"
                    />
            </DockPanel>
        </Border>
        <Border Style="{StaticResource CardPanel}" Grid.Column="2">
            <StackPanel  HorizontalAlignment="Center">

                <TextBlock Text="🔗 ÖSSZEKAPCSOLÁS"
                   FontWeight="Bold"
                   Foreground="#D4A843"
                   Margin="0,0,0,10"/>

                <Button Content="➕ Összekapcsolás"
                Width="140"
                Height="40"
                Click="osszkapcsolasbt_Click"/>
                <ListView x:Name="vendegEtkezesLv" Margin="0,10,0,0" Height="150">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Foreground="#F5ECD7">
                <Run Text="{Binding datum, StringFormat='{}{0:yyyy.MM.dd}'}"/>
                <Run Text=" - "/>
                <Run Text="{Binding leves.nev}"/>
                <Run Text=", "/>
                <Run Text="{Binding foetel.nev}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
        <!-- ── 2. oszlop: Napi étkezések ── -->
        <Border Style="{StaticResource CardPanel}" Grid.Column="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionHeader}">📋 NAPI ÉTKEZÉSEK</TextBlock>
                <ListView ItemsSource="{Binding napietkezesek}"
                          x:Name="napietkeslv"
                          BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,2" Padding="8,6"
                                    Background="#33291F" CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Text="{Binding datum, StringFormat='{}{0:yyyy.MM.dd}'}"
                                               FontWeight="Bold"
                                               Foreground="#D4A843"
                                               FontFamily="Georgia"
                                               FontSize="13"/>
                                    <TextBlock Foreground="#C5B49A" FontSize="11" Margin="0,3,0,0">
                                        <Run Text="🍲 " Foreground="#E8874A"/>
                                        <Run Text="{Binding leves.nev}"/>
                                        <LineBreak/>
                                        <Run Text="🍽 " Foreground="#E8874A"/>
                                        <Run Text="{Binding foetel.nev}"/>
                                        <LineBreak/>
                                        <Run Text="🍰 " Foreground="#E8874A"/>
                                        <Run Text="{Binding desszert.nev}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>

        <!-- ── 4. oszlop: Napi étkezés rögzítése ── -->
        <Border Style="{StaticResource CardPanel}" Grid.Column="3">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}">🗓 ÉTKEZÉS RÖGZÍTÉSE</TextBlock>

                <Label Content="Leves"/>
                <ComboBox DisplayMemberPath="nev" ItemsSource="{Binding levesek}" x:Name="levescb" />

                <Label Content="Főétel"/>
                <ComboBox DisplayMemberPath="nev" ItemsSource="{Binding foetelek}" x:Name="foetelcb"/>

                <Label Content="Desszert"/>
                <ComboBox DisplayMemberPath="nev" ItemsSource="{Binding desszertek}" x:Name="desszertcb"/>

                <Label Content="Dátum"/>
                <DatePicker x:Name="datumpicker"/>

                <Button Content="➕  Hozzáadás" x:Name="napietkezesbt" Click="napietkezesbt_Click"/>
            </StackPanel>
        </Border>
        
        <!-- ── 5. oszlop: Adatfelvitel ── -->
        <Border Style="{StaticResource CardPanel}" Grid.Column="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}">✏️ ÚJ ELEMEK</TextBlock>

                    <!-- Vendég -->
                    <TextBlock Text="Új vendég" Foreground="{StaticResource TextPrimary}"
                               FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Label Content="Név:" VerticalAlignment="Center"/>
                        <TextBox x:Name="hozzaadastb" Width="110"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <Label Content="Diák:" VerticalAlignment="Center"/>
                        <CheckBox x:Name="hozzaadascb" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="➕  Vendég hozzáadása" x:Name="hozzaadasbt" Click="hozzaadasbt_Click"/>

                    <Separator Style="{StaticResource Divider}"/>

                    <!-- Leves -->
                    <TextBlock Text="Új leves" Foreground="{StaticResource TextPrimary}"
                               FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Label Content="Név:" VerticalAlignment="Center"/>
                        <TextBox x:Name="levestb" Width="110"/>
                    </StackPanel>
                    <Button Content="➕  Leves hozzáadása" x:Name="levesbt" Click="levesbt_Click"/>

                    <Separator Style="{StaticResource Divider}"/>

                    <!-- Főétel -->
                    <TextBlock Text="Új főétel" Foreground="{StaticResource TextPrimary}"
                               FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Label Content="Név:" VerticalAlignment="Center"/>
                        <TextBox x:Name="foeteltb" Width="110"/>
                    </StackPanel>
                    <Button Content="➕  Főétel hozzáadása" x:Name="foetelbt" Click="foetelbt_Click"/>

                    <Separator Style="{StaticResource Divider}"/>

                    <!-- Desszert -->
                    <TextBlock Text="Új desszert" Foreground="{StaticResource TextPrimary}"
                               FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Label Content="Név:" VerticalAlignment="Center"/>
                        <TextBox x:Name="desszerttb" Width="110"/>
                    </StackPanel>
                    <Button Content="➕  Desszert hozzáadása" x:Name="desszertbt" Click="desszertbt_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
